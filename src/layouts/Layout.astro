---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  preloadImage?: string;
}

const { title, description = 'Manufacturers of hand-made guitar and bass amplifiers.', preloadImage } = Astro.props;
const nav = (await import('../data/nav.json')).default;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const bgImageUrl = `url('${base ? base + '/' : '/'}nva-background.png')`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <title>{title} | New Vintage Amplifiers</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ubuntu+Condensed&family=Oswald:wght@400;500&family=Archivo+Narrow:wght@400;500&display=swap"
      rel="stylesheet"
    />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <style is:global define:vars={{ bgImageUrl }}>
      .site-header { background-image: var(--bgImageUrl); }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href={base || '/'} class="logo" aria-label="New Vintage Amplifiers home">
          <img src={`${base}/logo.png`} alt="New Vintage Amplifiers" width="250" height="74" />
        </a>
        <button type="button" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="nav" aria-label="Main">
          <Nav items={nav} />
        </nav>
      </div>
    </header>
    <main id="main" class="main">
      <slot />
    </main>
    <Footer />
    <script>
      document.querySelector('.nav-toggle')?.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const nav = document.querySelector('.nav');
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        nav?.classList.toggle('open', !expanded);
      });
    </script>
  </body>
</html>
