---
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = (await import('../data/pages.json')).default as Array<{ path: string }>;
  return pages
    .filter((p) => p.path !== '/')
    .map((p) => {
      const slug = p.path.replace(/^\/|\/$/g, '');
      return { params: { slug } };
    });
}

const { slug } = Astro.params;
const path = '/' + (typeof slug === 'string' ? slug : (slug ?? []).join('/')) + '/';
const pages = (await import('../data/pages.json')).default as Array<{ path: string; title: string; content: string }>;
const page = pages.find((p) => p.path === path);

if (!page) {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return Astro.redirect(`${base}/404/`);
}

const title = page.title;
const rawContent = page.content ?? '';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const transformContent = (html: string) =>
  html
    .replace(/href="https?:\/\/(?:www\.)?newvintageamps\.com(\/[^"]*)?"/g, (_match, path) => {
      const localPath = path || '/';
      return `href="${localPath}"`;
    })
    .replace(/src="https?:\/\/(?:www\.)?newvintageamps\.com\/uploads\//g, `src="${base}/uploads/`)
    .replace(/src="\/uploads\//g, `src="${base}/uploads/`)
    .replace(/href="\//g, `href="${base}/`);

const content = rawContent ? transformContent(rawContent) : '';
---
<Layout title={title}>
  <article class="page-content">
    <h1>{title}</h1>
    {content ? <Fragment set:html={content} /> : null}
  </article>
</Layout>
