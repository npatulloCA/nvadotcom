---
import Layout from '../layouts/Layout.astro';
import pagesData from '../data/pages.json';

const contentModules = import.meta.glob<string>('../data/content/**/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
// Build path -> content map (keys may vary by environment)
const pathToContent: Record<string, string> = {};
for (const [key, content] of Object.entries(contentModules)) {
  const m = key.match(/content\/(.+)\.html$/);
  if (m) {
    const segments = m[1];
    const p = segments === 'index' ? '/' : `/${segments}/`;
    pathToContent[p] = content as string;
  }
}

export async function getStaticPaths() {
  const pages = pagesData as Array<{ path: string }>;
  return pages
    .filter((p) => p.path !== '/')
    .map((p) => {
      const slug = p.path.replace(/^\/|\/$/g, '');
      return { params: { slug } };
    });
}

const { slug } = Astro.params;
const segments: string[] = slug === undefined ? [] : Array.isArray(slug) ? slug : [slug];
const path = '/' + segments.join('/') + '/';
const pages = pagesData as Array<{ path: string; title: string }>;
const page = pages.find((p) => p.path === path);

if (!page) {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return Astro.redirect(`${base}/404/`);
}

const title = page.title;
const rawContent = pathToContent[path] ?? '';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const transformContent = (html: string) =>
  html
    .replace(/href="https?:\/\/(?:www\.)?newvintageamps\.com(\/[^"]*)?"/g, (_match, path) => {
      const localPath = path || '/';
      return `href="${localPath}"`;
    })
    .replace(/src="https?:\/\/(?:www\.)?newvintageamps\.com\/uploads\//g, `src="${base}/uploads/`)
    .replace(/src="\/uploads\//g, `src="${base}/uploads/`)
    .replace(/href="\//g, `href="${base}/`);

const content = rawContent ? transformContent(rawContent) : '';
const isWidePage =
  path.startsWith('/guitar-amps/') ||
  path.startsWith('/bass-amps/') ||
  path.startsWith('/speaker-cabinets/') ||
  path.startsWith('/about-nva/legacymodels/') ||
  path === '/artists/';
---
<Layout title={title}>
  <article class:list={['page-content', { 'page-content--wide': isWidePage }]}>
    <h1>{title}</h1>
    {content ? <Fragment set:html={content} /> : null}
  </article>
</Layout>
