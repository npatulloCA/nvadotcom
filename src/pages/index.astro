---
import Layout from '../layouts/Layout.astro';
import Carousel from '../components/Carousel.astro';

const pages = (await import('../data/pages.json')).default;
const home = pages.find((p: { path: string }) => p.path === '/');
const title = home?.title === 'home' ? 'Home' : (home?.title || 'Home');
const rawContent = home?.content ?? '';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const carouselSlides = [
  { src: `${base}/carousel/hoppusbanner.png`, alt: 'New Vintage Amplifiers on stage' },
  { src: `${base}/carousel/112banner.png`, alt: 'New Vintage Amplifiers 1x12 cabinet' },
  { src: `${base}/carousel/roguebanner.png`, alt: 'Rogue 50 amplifier head' },
  { src: `${base}/carousel/mkbanner.png`, alt: 'New Vintage Amplifiers combo' },
];
const transformContent = (html: string) =>
  html
    // Rewrite old absolute WordPress links on newvintageamps.com to local paths
    .replace(/href="https?:\/\/(?:www\.)?newvintageamps\.com(\/[^"]*)?"/g, (_match, path) => {
      const localPath = path || '/';
      return `href="${localPath}"`;
    })
    // Rewrite images that pointed at the old domain to local uploads
    .replace(/src="https?:\/\/(?:www\.)?newvintageamps\.com\/uploads\//g, `src="${base}/uploads/`)
    // Fix image paths that were root-relative (e.g. /uploads/...)
    .replace(/src="\/uploads\//g, `src="${base}/uploads/`)
    // Fix internal links that were root-relative (e.g. /guitar-amps/)
    .replace(/href="\//g, `href="${base}/`);

const content = rawContent ? transformContent(rawContent) : '';
---
<Layout title={title} preloadImage={`${base}/carousel/hoppusbanner.png`}>
  <Carousel slides={carouselSlides} />
  <article class="page-content">
    {content ? (
      <Fragment set:html={content} />
    ) : (
      <p>New Vintage Amplifiers — manufacturers of hand-made guitar and bass amplifiers.</p>
    )}
  </article>
</Layout>
