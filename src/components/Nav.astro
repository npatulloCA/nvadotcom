---
interface NavItem {
  title: string;
  path: string;
  children: NavItem[];
}

const { items } = Astro.props as { items: NavItem[] };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Normalize current path to be relative to the base so active states work
const currentPath = Astro.url.pathname
  .replace(base, '')
  .replace(/\/$/, '') || '/';

const toHref = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};
---

<ul class="nav-list">
  {items.map((item) => {
    const itemPath = item.path.replace(/\/$/, '');
    const isActive = currentPath === itemPath || (itemPath !== '/' && currentPath.startsWith(itemPath));
    const hasChildren = item.children && item.children.length > 0;
    const href = toHref(item.path);
    return (
      <li class={`nav-item ${hasChildren ? 'has-children' : ''}`}>
        <a href={href} class={isActive ? 'active' : ''}>{item.title}</a>
        {hasChildren && (
          <ul class="nav-sublist">
            {item.children.map((child) => (
              <li class="nav-subitem">
                <a
                  href={toHref(child.path)}
                  class={currentPath === child.path.replace(/\/$/, '') ? 'active' : ''}
                >
                  {child.title}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    );
  })}
</ul>
