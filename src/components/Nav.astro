---
interface NavItem {
  title: string;
  path: string;
  children: NavItem[];
}

const { items } = Astro.props as { items: NavItem[] };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Normalize current path to be relative to the base so active states work
const currentPath = Astro.url.pathname
  .replace(base, '')
  .replace(/\/$/, '') || '/';

const toHref = (path: string) => {
  if (path === '/') return base || '/';
  return `${base}${path}`;
};
---

<ul class="nav-list">
  {items.map((item) => {
    const itemPath = item.path.replace(/\/$/, '');
    const isActive = currentPath === itemPath || (itemPath !== '/' && currentPath.startsWith(itemPath));
    const hasChildren = item.children && item.children.length > 0;
    const href = toHref(item.path);
    return (
      <li class={`nav-item ${hasChildren ? 'has-children' : ''}`}>
        <a href={href} class={isActive ? 'active' : ''}>{item.title}</a>
        {hasChildren && (
          <ul class="nav-sublist">
            {item.children.map((child) => {
              const childHasChildren = child.children && child.children.length > 0;
              const childPath = child.path.replace(/\/$/, '');
              return (
                <li class={`nav-subitem ${childHasChildren ? 'has-children' : ''}`}>
                  <a
                    href={toHref(child.path)}
                    class={currentPath === childPath || (childPath !== '/' && currentPath.startsWith(childPath)) ? 'active' : ''}
                  >
                    {child.title}
                  </a>
                  {childHasChildren && (
                    <ul class="nav-sublist-deep">
                      {child.children.map((grandchild) => (
                        <li class="nav-subitem">
                          <a
                            href={toHref(grandchild.path)}
                            class={currentPath === grandchild.path.replace(/\/$/, '') ? 'active' : ''}
                          >
                            {grandchild.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        )}
      </li>
    );
  })}
</ul>
